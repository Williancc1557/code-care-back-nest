# Copy to .env and adjust. Must match docker-compose credentials if you use the bundled Postgres.

POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/auth_nest

# Required in production — used to sign JWTs (see src/routes/auth/auth.module.ts)
JWT_SECRET=replace-with-a-long-random-string

# Optional: override docker-compose postgres service (defaults match POSTGRES_URL above)
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=auth_nest
